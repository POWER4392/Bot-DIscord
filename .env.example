# =========================================================
#   Discord Bot — Mẫu cấu hình biến môi trường (.env)
#   Copy file này thành '.env' và điền các giá trị thực.
#   KHÔNG COMMIT file .env lên GitHub!
# =========================================================

# ----------------------------------------------------------
# [BẮT BUỘC] Discord Bot Token
# Lấy tại: https://discord.com/developers/applications
# ----------------------------------------------------------
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# ----------------------------------------------------------
# [BẮT BUỘC] API Secret Key
# Dùng để xác thực giữa Web Dashboard và Bot API.
# Đặt chuỗi ngẫu nhiên, bí mật (ít nhất 32 ký tự).
# ----------------------------------------------------------
API_SECRET=YOUR_SECURE_RANDOM_API_SECRET_HERE

# ----------------------------------------------------------
# [TÙY CHỌN] Gemini AI API Key
# Lấy tại: https://aistudio.google.com/app/apikey
# Để trống nếu không sử dụng tính năng AI Chatbot.
# ----------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------
# [TÙY CHỌN] Neon PostgreSQL Database URL
# Kết nối tới Neon.tech thay vì SQLite cục bộ.
# Lấy tại: https://console.neon.tech → Project → Connection string
#
# Định dạng: postgresql://user:password@host/dbname?sslmode=require
# Ví dụ:     postgresql://bot_user:abc123@ep-cool-fog.us-east-2.aws.neon.tech/botdb?sslmode=require
#
# Để TRỐNG để dùng SQLite cục bộ (databases/bot_core.db).
# ----------------------------------------------------------
DATABASE_URL=

# ----------------------------------------------------------
# [TÙY CHỌN] Cổng HTTP API Server
# Mặc định: 8080. Render Cloud sẽ tự đặt qua biến PORT.
# ----------------------------------------------------------
PORT=8080
