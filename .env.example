# Discord Bot Configuration Template
# Copy this file to a new file named '.env' and fill in your values.

# Discord Bot Token (Required if not set in config.json)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# API Secret Key for GUI/API communication (Required if not set in config.json)
API_SECRET=YOUR_SECURE_API_SECRET_HERE

# PostgreSQL Database Connection URL (Optional, defaults to local SQLite db)
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# Port for the GUI API Web Server (Optional, defaults to 8080)
PORT=8080
